# Database
DB_URL=jdbc:postgresql://localhost:5432/torome_store
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT (min 256-bit secret)
JWT_SECRET=change-this-to-a-secure-random-secret-min-256-bits

# AI Orchestrator
AI_ORCHESTRATOR_URL=http://localhost:8000

# Microservice URLs (local dev)
USER_SERVICE_URL=http://localhost:9001
PRODUCT_SERVICE_URL=http://localhost:9002
ORDER_SERVICE_URL=http://localhost:9003
PAYMENT_SERVICE_URL=http://localhost:9004

# Spring Profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev
